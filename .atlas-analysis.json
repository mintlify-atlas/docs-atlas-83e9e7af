{
  "projectType": "saas",
  "projectName": "LibraEase",
  "projectDescription": "A full-stack library management system with role-based access for librarians and members, supporting book cataloging, checkout, and email notifications.",
  "theme": "almond",
  "primaryColor": "#22BC66",
  "lightColor": "#d4f4e2",
  "darkColor": "#16803f",
  "navigation": {
    "tabs": [
